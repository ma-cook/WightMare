        "backgroundColor": "#ffffff"
      }
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "867a81a6-c9f7-4060-a372-9a803114fa94"
      }
    },
    "owner": "mitchmaster"
  }
