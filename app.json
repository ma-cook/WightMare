{
  "expo": {
    "name": "WightMare",
    "slug": "wightmare",
    "version": "27.0.0",
    "orientation": "landscape",
    "icon": "./assests/icon.PNG",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assests/icon.PNG",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
