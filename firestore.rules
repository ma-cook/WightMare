rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Leaderboard: anyone can read; anyone can create (but not update/delete).
    match /leaderboard/{entry} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Web leaderboard: same rules, separate collection.
    match /leaderboard_web/{entry} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
